# === Wallet Private Key ===
# 64 hex characters, no 0x prefix
ARCHIVER_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# === Chain Configuration (Arc Testnet) ===
ARCH_RPC_URL=https://rpc.testnet.arc.network
ARCH_CHAIN_ID=5042002